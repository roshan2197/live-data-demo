{
  "name": "live-data-demo-backend",
  "version": "1.0.0",
  "description": "Live data demo backend with WebSocket support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:debezium": "node server-debezium.js",
    "dev:debezium": "node --watch server-debezium.js",
    "start:debezium:no-redis": "node server-debezium-no-redis.js",
    "dev:debezium:no-redis": "node --watch server-debezium-no-redis.js",
    "start:events-only": "node server-events-only.js",
    "dev:events-only": "node --watch server-events-only.js"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "redis": "^4.7.1",
    "socket.io": "^4.6.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
